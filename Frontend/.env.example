# Google Maps JavaScript API key (enable "Maps JavaScript API" in Google Cloud Console).
# Copy this file to .env and fill in your key, then restart `npm run dev`.
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_js_api_key

# Note: Google Sign-In uses the OAuth 2.0 redirect flow handled entirely by the
# backend, so no Google client id is needed here. Configure GOOGLE_CLIENT_ID,
# GOOGLE_CLIENT_SECRET and GOOGLE_REDIRECT_URI in the Backend/.env instead.

# Backend API origin.
# - Local dev: leave this UNSET. The app uses relative "/api" paths and the Vite
#   dev proxy forwards them to http://localhost:5000 (see VITE_API_TARGET below).
# - Production (e.g. Vercel): set this to your deployed backend origin so the
#   frontend calls it directly. No trailing slash, no "/api" suffix.
#   Example: VITE_API_BASE_URL=https://your-backend.onrender.com
VITE_API_BASE_URL=https://your-backend.onrender.com

# Optional: override the backend API target for the dev proxy (defaults to http://localhost:5000)
VITE_API_TARGET=http://localhost:5000
