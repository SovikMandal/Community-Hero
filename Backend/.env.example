# ----------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ----------------------------------------------------------------------------
# Database (PostgreSQL / Prisma)
# ----------------------------------------------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/community_hero?schema=public"

# ----------------------------------------------------------------------------
# JWT Authentication
# ----------------------------------------------------------------------------
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace_this_with_another_long_random_secret
REFRESH_TOKEN_EXPIRES_IN=30d

# ----------------------------------------------------------------------------
# Google Sign-In (OAuth 2.0 authorization-code flow)
# Create an "OAuth 2.0 Client ID" (Web application) at:
#   https://console.cloud.google.com/apis/credentials
# Add this Authorized redirect URI to the client (must match GOOGLE_REDIRECT_URI):
#   http://localhost:5000/api/auth/google/callback
# (Add your production callback URL there too, e.g. https://api.yourdomain.com/api/auth/google/callback)
# Set the app name + logo on the OAuth consent screen — it shows as
# "Choose an account to continue to <app name>".
# ----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# ----------------------------------------------------------------------------
# Cloudinary (image/video storage)
# ----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ----------------------------------------------------------------------------
# AI Provider Switch — "gemini" or "cloudflare"
# ----------------------------------------------------------------------------
AI_PROVIDER=gemini

# ----------------------------------------------------------------------------
# Google Gemini AI (Google AI Studio)
# ----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash

# ----------------------------------------------------------------------------
# Cloudflare Workers AI (free alternative)
# Get credentials at: https://dash.cloudflare.com → AI → Workers AI
# ----------------------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# ----------------------------------------------------------------------------
# Email (Brevo SMTP)
# Get credentials at: https://app.brevo.com → SMTP & API
# ----------------------------------------------------------------------------
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_login
SMTP_PASS=your_brevo_smtp_key
MAIL_FROM=noreply@yourdomain.com
